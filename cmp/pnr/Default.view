# Version:1.0 MMMC View Definition File
# Do Not Remove Above Line
create_library_set -name gscl45nm_ls -timing {lib/gscl45nm.tlf}
create_constraint_mode -name fsm_cm -sdc_files {netlist/frequency_divider_by3.sdc}
create_delay_corner -name gscl45nm_dc -library_set {gscl45nm_ls}
create_analysis_view -name fsm_av -constraint_mode {fsm_cm} -delay_corner {gscl45nm_dc}
set_analysis_view -setup {fsm_av} -hold {fsm_av}
